<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>وزارة التربية العراقية · قاعدة التدريسيين</title>
    <!-- Google Fonts (Cairo + modern sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', 'Inter', sans-serif;
            background: linear-gradient(145deg, #f0f4f8 0%, #e9eff5 100%);
            min-height: 100vh;
            color: #162b3a;
            line-height: 1.6;
            padding: 20px;
        }

        /* professional cards & containers */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 40px;
            box-shadow: 0 25px 50px -10px rgba(0, 40, 60, 0.25);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ===== START PAGE STYLES (visible by default) ===== */
        #start-page {
            display: block;
            animation: fadeSlideUp 0.8s ease;
        }

        #data-page {
            display: none;
            animation: fadeSlideUp 0.8s ease;
        }

        @keyframes fadeSlideUp {
            0% { opacity: 0; transform: translateY(18px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        /* header & nav */
        .iraq-header {
            background: #0f2b3f;
            color: white;
            border-radius: 60px 60px 30px 30px;
            padding: 2rem 2.5rem;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 25px;
            box-shadow: 0 15px 30px -10px #0a1e2b;
            border: 1px solid #3d627c;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .logo-icon {
            font-size: 3rem;
            color: #ffd966;
            filter: drop-shadow(0 4px 6px #00000033);
        }

        .ministry-title h1 {
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1.3;
        }

        .ministry-title h1 span {
            font-weight: 300;
            font-size: 1.2rem;
            color: #bcd9f0;
            display: block;
        }

        .nav-button {
            background: rgba(255,255,255,0.1);
            border: 1.5px solid #7899b3;
            color: white;
            padding: 14px 38px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            backdrop-filter: blur(5px);
        }

        .nav-button i {
            font-size: 1.5rem;
        }

        .nav-button:hover {
            background: #1f4b6e;
            border-color: #ffd966;
            transform: scale(1.02);
        }

        /* hero section (start page) */
        .hero-moe {
            background: linear-gradient(115deg, #ffffffd9 0%, #f4faffd9 100%), url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text x=%225%22 y=%2220%22 font-size=%2218%22 fill=%22%231e3c5c10%22>وزارة التربية</text><text x=%2260%22 y=%2280%22 font-size=%2224%22 fill=%22%231e3c5c10%22>العراقية</text></svg>');
            background-size: cover;
            border-radius: 50px;
            padding: 60px 50px;
            margin-bottom: 45px;
            box-shadow: 0 20px 40px rgba(12, 40, 60, 0.25);
            border: 1px solid #ffffffaa;
        }

        .hero-content h2 {
            font-size: 3rem;
            font-weight: 700;
            color: #073b4e;
            line-height: 1.3;
        }

        .hero-content h2 i {
            color: #b68b40;
            margin-left: 12px;
        }

        .hero-stats {
            display: flex;
            gap: 35px;
            margin: 40px 0 20px;
            flex-wrap: wrap;
        }

        .stat-item {
            background: #ffffffcc;
            backdrop-filter: blur(8px);
            padding: 20px 35px;
            border-radius: 70px;
            font-weight: 600;
            border: 1px solid white;
            box-shadow: 0 8px 18px #0000001a;
        }

        .stat-item i {
            color: #b7742e;
            font-size: 2rem;
            margin-left: 12px;
        }

        .guide-badge {
            background: #06212e;
            color: white;
            padding: 20px 40px;
            border-radius: 90px;
            display: inline-flex;
            align-items: center;
            gap: 25px;
            font-size: 1.4rem;
            margin-top: 25px;
            border: 1px solid #ffd966;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin: 60px 0 30px;
        }

        .feature-card {
            background: white;
            padding: 40px 30px;
            border-radius: 40px;
            text-align: center;
            transition: all 0.25s;
            border: 1px solid #c3d9eb;
            box-shadow: 0 16px 30px -14px #1e3c5c33;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            border-color: #9f7e4c;
        }

        .feature-card i {
            font-size: 3.5rem;
            color: #1f5979;
            margin-bottom: 25px;
        }

        .feature-card h3 {
            font-size: 1.8rem;
            margin-bottom: 15px;
        }

        .btn-primary {
            background: #1f4b6e;
            border: none;
            color: white;
            padding: 20px 60px;
            border-radius: 70px;
            font-size: 1.7rem;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 14px 25px #0a3143;
            transition: 0.2s;
            border: 1px solid #5982a3;
            display: inline-flex;
            align-items: center;
            gap: 20px;
        }

        .btn-primary:hover {
            background: #123a52;
            box-shadow: 0 10px 30px #022b40;
            transform: scale(1.02);
        }

        /* ===== data page styles (elevated) ===== */
        .data-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 35px;
            background: #0f2b3f;
            border-radius: 70px;
            padding: 15px 35px;
            color: white;
        }

        .back-btn {
            background: #2f5e83;
            border: none;
            color: white;
            padding: 12px 35px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.15s;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .back-btn:hover {
            background: #173f5c;
        }

        .form-panel {
            background: #ffffffed;
            backdrop-filter: blur(6px);
            border-radius: 48px;
            padding: 30px;
            margin-bottom: 40px;
            border: 1px solid #ffffff;
            box-shadow: 0 22px 40px -15px #1f3a4b;
        }

        .field-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 18px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .input-group label {
            font-weight: 700;
            color: #1e3c5c;
            font-size: 0.95rem;
            margin-right: 10px;
        }

        .input-group input, .input-group select {
            background: white;
            border: 1.5px solid #cbdae7;
            border-radius: 28px;
            padding: 12px 20px;
            font-size: 0.95rem;
            font-family: 'Cairo', sans-serif;
            transition: 0.2s;
        }

        .input-group input:focus, .input-group select:focus {
            border-color: #0077be;
            box-shadow: 0 0 0 4px #a6c8e4;
            outline: none;
        }

        .action-buttons {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin: 30px 0 10px;
            flex-wrap: wrap;
        }

        .btn-save {
            background: #1a5235;
            border: none;
            color: white;
            padding: 14px 50px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: 600;
            box-shadow: 0 8px 18px #1b4b2e;
            cursor: pointer;
            transition: 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 12px;
        }

        .btn-reset {
            background: #5f6c7a;
            border: none;
            color: white;
            padding: 14px 40px;
            border-radius: 50px;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .table-wrapper {
            overflow-x: auto;
            background: #ffffffde;
            border-radius: 40px;
            padding: 5px;
            box-shadow: 0 20px 40px -10px #173045;
            border: 1px solid white;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
            min-width: 1700px;
        }

        th {
            background: #1f3f58;
            color: white;
            font-weight: 600;
            padding: 15px 5px;
            border-left: 1px solid #38698b;
            text-align: center;
        }

        td {
            padding: 12px 5px;
            border-bottom: 1px solid #cbdae7;
            text-align: center;
            background-color: white;
        }

        .delete-btn {
            background: #b53b3b;
            color: white;
            border: none;
            border-radius: 40px;
            padding: 6px 20px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.1s;
        }

        .delete-btn:hover {
            background: #831f1f;
        }

        .footer-note {
            margin-top: 20px;
            color: #1f4b6e;
            font-weight: 500;
        }
    </style>
</head>
<body>
<div class="container">
    <!-- ========== START PAGE (الرئيسية) ========== -->
    <div id="start-page">
        <div class="iraq-header">
            <div class="logo-area">
                <i class="fas fa-landmark logo-icon"></i>
                <div class="ministry-title">
                    <h1>وزارة التربية العراقية <span>جمهورية العراق – مجلس الوزراء</span></h1>
                </div>
            </div>
            <div class="nav-button" id="goToDataBtnStart">
                <i class="fas fa-arrow-left"></i>
                <span>الدخول إلى قاعدة البيانات</span>
            </div>
        </div>

        <div class="hero-moe">
            <div class="hero-content">
                <h2><i class="fas fa-chalkboard-teacher"></i> قاعدة بيانات التدريسيين <br>النظام المتكامل للملاكات التربوية</h2>
                <div class="hero-stats">
                    <div class="stat-item"><i class="fas fa-user-graduate"></i> أكثر من 450,000 تدريسي</div>
                    <div class="stat-item"><i class="fas fa-school"></i> 32,000 مدرسة ومعهد</div>
                    <div class="stat-item"><i class="fas fa-scroll"></i> توثيق معتمد منذ ٢٠٠٣</div>
                </div>
                <div class="guide-badge">
                    <i class="fas fa-database"></i>
                    <span>سجل محلي آمن – جميع الحقول معتمدة حسب دليل الوزارة</span>
                </div>
            </div>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <i class="fas fa-id-card-alt"></i>
                <h3>بيانات شاملة</h3>
                <p>الاسم الرباعي، أسماء الأجداد، الأم، الجنس، التخصص العام والدقيق، الجهات المانحة، تواريخ المنح.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-laptop-medical"></i>
                <h3>حفظ محلي متين</h3>
                <p>IndexedDB – تعمل بدون إنترنت، بياناتك تبقى في جهازك بأمان تام.</p>
            </div>
            <div class="feature-card">
                <i class="fas fa-table"></i>
                <h3>27 حقلاً مخصصاً</h3>
                <p>مرتبة حسب طلب الوزارة: الأسم الأول، أسم الأب، أسم الجد، والد الجد، اللقب، الجنس ... حتى الشهادة (مكرر)</p>
            </div>
        </div>

        <div style="text-align: center; margin: 60px 0 30px;">
            <button class="btn-primary" id="enterDataBtn">
                <i class="fas fa-arrow-left"></i>
                الانتقال إلى قاعدة التدريسيين
            </button>
        </div>
        <div style="height: 30px;"></div>
    </div>

    <!-- ========== DATA PAGE (صفحة الإدخال والجدول) ========== -->
    <div id="data-page">
        <div class="data-header">
            <div style="display: flex; align-items: center; gap: 25px;">
                <i class="fas fa-database" style="font-size: 2.2rem; color: #ffd966;"></i>
                <h2 style="font-size: 2rem;">سجل التدريسيين - وزارة التربية</h2>
            </div>
            <button class="back-btn" id="backToStartBtn"><i class="fas fa-arrow-right"></i> العودة للرئيسية</button>
        </div>

        <!-- form panel -->
        <div class="form-panel">
            <div class="field-grid" id="inputFieldsContainer"></div>
            <div class="action-buttons">
                <button class="btn-save" id="saveBtn"><i class="fas fa-save"></i> حفظ في السجل المحلي</button>
                <button class="btn-reset" id="resetBtn"><i class="fas fa-undo-alt"></i> إعادة تعيين</button>
            </div>
        </div>

        <!-- table display -->
        <div class="table-wrapper">
            <table id="dataTable">
                <thead id="tableHeader"></thead>
                <tbody id="tableBody"><tr><td colspan="30" style="text-align:center; padding:40px;">يرجى الانتظار ...</td></tr></tbody>
            </table>
        </div>
        <div class="footer-note">
            <i class="fas fa-shield-alt"></i> التخزين في IndexedDB (local database) – البيانات لا تغادر متصفحك.
        </div>
    </div>
</div>

<script>
    (function() {
        // ========== FIELDS ORDER (exactly as requested, with duplicate الشهادة) ==========
        const FIELDS = [
            "الأسم الأول", "أسم الأب", "أسم الجد", "أسم والد الجد", "اللقب", "الجنس",
            "أسم جد الأم", "أسم أب الأم", "أسم الأم", "القسم", "الجنسية", "البلد المانح",
            "تاريخ منح اللقب الخاص بالتدريسي", "رقم الموبايل", "القسم المانح", "التخصص العام",
            "الجامعة المانحة للقب او العنوان", "التخصص الدقيق", "اللقب العلمي", "تاريخ منح",
            "الخاص", "الموبايل", "الشهادة تاريخ الحصول على", "الكلية المانحة", "الشهادة", "الشهادة"
        ];

        // table headers (second duplicate marked)
        const TABLE_HEADERS = [...FIELDS];
        let cnt = {};
        for (let i = 0; i < TABLE_HEADERS.length; i++) {
            let h = TABLE_HEADERS[i];
            if (cnt[h]) {
                cnt[h]++;
                TABLE_HEADERS[i] = h + " (٢)";
            } else {
                cnt[h] = 1;
            }
        }

        // ========== IndexedDB ==========
        const DB_NAME = 'EducatorsDB';
        const STORE_NAME = 'educators';
        const DB_VERSION = 3;

        function openDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(DB_NAME, DB_VERSION);
                req.onerror = () => reject('فشل فتح DB');
                req.onsuccess = (e) => resolve(e.target.result);
                req.onupgradeneeded = (e) => {
                    const db = e.target.result;
                    if (!db.objectStoreNames.contains(STORE_NAME)) {
                        db.createObjectStore(STORE_NAME, { keyPath: 'id', autoIncrement: true });
                    }
                };
            });
        }

        async function saveRecord(data) {
            const db = await openDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(STORE_NAME, 'readwrite');
                const store = tx.objectStore(STORE_NAME);
                const clean = { ...data };
                delete clean.id;
                const req = store.add(clean);
                req.onsuccess = () => resolve(req.result);
                req.onerror = (e) => reject(e);
                tx.oncomplete = () => db.close();
            });
        }

        async function getAllRecords() {
            const db = await openDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(STORE_NAME, 'readonly');
                const store = tx.objectStore(STORE_NAME);
                const req = store.getAll();
                req.onsuccess = () => resolve(req.result || []);
                req.onerror = reject;
                tx.oncomplete = () => db.close();
            });
        }

        async function deleteRecord(id) {
            const db = await openDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(STORE_NAME, 'readwrite');
                const store = tx.objectStore(STORE_NAME);
                const req = store.delete(id);
                req.onsuccess = () => resolve(true);
                req.onerror = reject;
                tx.oncomplete = () => db.close();
            });
        }

        // ========== BUILD FORM FIELDS with col_ indexes ==========
        const container = document.getElementById('inputFieldsContainer');
        function buildForm() {
            container.innerHTML = '';
            FIELDS.forEach((label, idx) => {
                const div = document.createElement('div');
                div.className = 'input-group';
                const lbl = document.createElement('label');
                lbl.htmlFor = `col_${idx}`;
                lbl.textContent = label;
                let input;
                if (label === 'الجنس') {
                    input = document.createElement('select');
                    input.id = `col_${idx}`;
                    input.name = `col_${idx}`;
                    input.innerHTML = `<option value="ذكر">ذكر</option><option value="أنثى">أنثى</option>`;
                } else {
                    input = document.createElement('input');
                    input.type = 'text';
                    input.id = `col_${idx}`;
                    input.placeholder = label;
                }
                div.appendChild(lbl);
                div.appendChild(input);
                container.appendChild(div);
            });
        }
        buildForm();

        function getFormObject() {
            const obj = {};
            FIELDS.forEach((_, idx) => {
                const el = document.getElementById(`col_${idx}`);
                obj[`col_${idx}`] = el ? el.value.trim() : '';
            });
            return obj;
        }

        function resetForm() {
            FIELDS.forEach((_, idx) => {
                const el = document.getElementById(`col_${idx}`);
                if (el) {
                    if (el.tagName === 'SELECT') el.selectedIndex = 0;
                    else el.value = '';
                }
            });
        }

        // ========== RENDER TABLE ==========
        async function renderTable() {
            const thead = document.getElementById('tableHeader');
            const tbody = document.getElementById('tableBody');
            try {
                const records = await getAllRecords();
                thead.innerHTML = '<tr>' + TABLE_HEADERS.map(h => `<th>${h}</th>`).join('') + '<th>إجراء</th></tr>';
                if (records.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="${TABLE_HEADERS.length+1}" style="text-align:center; padding:40px;">لا يوجد تدريسيون بعد ...</td></tr>`;
                    return;
                }
                let rows = '';
                records.forEach(rec => {
                    rows += '<tr>';
                    for (let i = 0; i < FIELDS.length; i++) {
                        rows += `<td>${rec[`col_${i}`] || ''}</td>`;
                    }
                    rows += `<td><button class="delete-btn" data-id="${rec.id}"><i class="fas fa-trash-alt"></i> حذف</button></td></tr>`;
                });
                tbody.innerHTML = rows;
                document.querySelectorAll('.delete-btn').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const id = Number(e.currentTarget.getAttribute('data-id'));
                        if (confirm('تأكيد حذف هذا التدريسي من السجل المحلي؟')) {
                            await deleteRecord(id);
                            renderTable();
                        }
                    });
                });
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="30">خطأ: ${err}</td></tr>`;
            }
        }

        // ========== PAGE NAVIGATION ==========
        const startPage = document.getElementById('start-page');
        const dataPage = document.getElementById('data-page');

        function showStart() {
            startPage.style.display = 'block';
            dataPage.style.display = 'none';
        }

        function showData() {
            startPage.style.display = 'none';
            dataPage.style.display = 'block';
            renderTable(); // refresh when showing data page
        }

        document.getElementById('goToDataBtnStart').addEventListener('click', showData);
        document.getElementById('enterDataBtn').addEventListener('click', showData);
        document.getElementById('backToStartBtn').addEventListener('click', showStart);

        // ========== SAVE / RESET ==========
        document.getElementById('saveBtn').addEventListener('click', async () => {
            const data = getFormObject();
            try {
                await saveRecord(data);
                resetForm();
                renderTable();
            } catch (e) {
                alert('خطأ بالحفظ: ' + e);
            }
        });

        document.getElementById('resetBtn').addEventListener('click', resetForm);

        // pre-render table for fast view (data page hidden initially)
        renderTable();
    })();
</script>
<!-- نهاية المشروع – صفحتان بتصميم احترافي تربوي -->
</body>
</html>
